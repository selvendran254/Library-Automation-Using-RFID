SECRET_KEY=change-this-to-a-long-random-string
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/library_rfid
FLASK_DEBUG=1

# Staff default login (created on first run)
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_PASSWORD=admin123
DEFAULT_ADMIN_NAME=Library Admin
DEFAULT_ADMIN_PHONE=9876543210

# RFID Hardware — hid | serial
RFID_MODE=hid
RFID_SERIAL_PORT=/dev/ttyUSB0
RFID_BAUD_RATE=9600

# SMS: simulated | fast2sms | msg91 | twilio
SMS_PROVIDER=simulated
FAST2SMS_API_KEY=
MSG91_AUTH_KEY=
MSG91_SENDER_ID=LIBRFID
MSG91_ROUTE=4

# Email (optional)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=
